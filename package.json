{
  "name": "clash-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir ./dist",
    "start": "bun dist/index.js",
    "db:generate": "bunx drizzle-kit generate:pg",
    "db:migrate": "bunx drizzle-kit up:pg",
    "db:push": "bunx drizzle-kit push:pg",
    "db:drop": "drizzle-kit drop",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check:pg"
  },
  "dependencies": {
    "drizzle-orm": "^0.29.3",
    "glicko2.ts": "^1.3.2",
    "jose": "^6.1.3",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/pg": "^8.10.9",
    "bun-types": "latest",
    "drizzle-kit": "^0.20.13",
    "ts-proto": "^1.166.2",
    "typescript": "^5.3.3"
  }
}